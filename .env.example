# ── Supabase ──────────────────────────────────────────────────
# Public (safe to expose to browser via NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_SUPABASE_URL=https://olsudkakojivihbzzpho.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-from-supabase-dashboard

# Server-only (NEVER expose to client — no NEXT_PUBLIC_ prefix)
SUPABASE_URL=https://olsudkakojivihbzzpho.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-from-supabase-dashboard

# ── GitHub ─────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_xxxx
# Comma-separated owner/repo for cron (e.g. Seema2211/fixmybuild-test-repo)
GITHUB_REPOS=owner/repo

# ── Groq LLM ──────────────────────────────────────────────────
OPENAI_API_KEY=gsk_xxxx

# ── Cron Protection (optional) ─────────────────────────────────
CRON_SECRET=optional-secret
